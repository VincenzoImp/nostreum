{
  "name": "nostreum",
  "version": "0.1.0",
  "private": true,
  "description": "Nostr social client with on-chain Ethereum identity verification powered by nostr-linkr",
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "scripts": {
    "dev": "yarn workspace @se-2/nextjs dev",
    "build": "yarn workspace @se-2/nextjs build",
    "start": "yarn workspace @se-2/nextjs serve",
    "lint": "yarn workspace @se-2/nextjs lint",
    "format": "yarn workspace @se-2/nextjs format",
    "check-types": "yarn workspace @se-2/nextjs check-types",
    "vercel": "yarn workspace @se-2/nextjs vercel",
    "vercel:yolo": "yarn workspace @se-2/nextjs vercel:yolo",
    "postinstall": "husky install",
    "precommit": "lint-staged"
  },
  "devDependencies": {
    "husky": "~9.1.6",
    "lint-staged": "~13.2.2"
  },
  "packageManager": "yarn@3.2.3",
  "engines": {
    "node": ">=20.18.3"
  },
  "license": "MIT",
  "author": "Vincenzo Imp",
  "repository": {
    "type": "git",
    "url": "https://github.com/VincenzoImp/nostreum"
  },
  "resolutions": {
    "brace-expansion": ">=5.0.7",
    "cookie": ">=0.7.0",
    "debug": ">=4.3.1",
    "parse-duration": ">=2.1.3",
    "path-to-regexp": ">=6.3.0",
    "postcss": ">=8.5.12",
    "semver": ">=7.5.2",
    "tar": ">=7.5.19",
    "tmp": ">=0.2.6",
    "undici": ">=6.27.0",
    "ws": ">=8.21.0"
  }
}
